{% if site.type == 'php' %}
<div class="card mb-4">
  <div class="card-header"><h2 class="card-title">{% trans %}WordPress Auto-Updates{% endtrans %}</h2></div>
  <div class="card-body">
    <p class="text-muted small">{% trans %}Runs daily via /etc/cron.daily/clp-wp-updates. Only sites with a wp-config.php in the site root are processed.{% endtrans %}</p>
    <form method="POST" action="{{ path('clp_site_wp_auto_update', {'domainName': site.domainName}) }}">
      <input type="hidden" name="_token" value="{{ csrf_token('default') }}">
      <div class="row">
        <div class="col-md-6">
          <label class="col-form-label" for="wpAutoUpdate">{% trans %}Mode{% endtrans %}</label>
          <select class="form-control" id="wpAutoUpdate" name="wpAutoUpdate">
            {% set current = site.wpAutoUpdate|default('none') %}
            <option value="none" {% if current == 'none' %}selected{% endif %}>{% trans %}Disabled{% endtrans %}</option>
            <option value="security" {% if current == 'security' %}selected{% endif %}>{% trans %}Security (core minor only){% endtrans %}</option>
            <option value="all" {% if current == 'all' %}selected{% endif %}>{% trans %}All (core + plugins + themes){% endtrans %}</option>
          </select>
        </div>
      </div>
      <div class="mt-3">
        <button type="submit" class="btn btn-blue">{% trans %}Save{% endtrans %}</button>
      </div>
    </form>
  </div>
</div>
{% endif %}
