{% extends 'Frontend/layout.html.twig' %}

{% block pageTitle %}{% trans %}CDN{% endtrans %}{% endblock %}

{% block body %}
<div class="container-fluid container-limited-width">
  <div class="site-container">
    {{ include('Frontend/Site/Partial/site-info.html.twig', {'site': site}) }}
    <div class="site-content-container">
      {{ include('Frontend/Site/Partial/tab-container.html.twig', {'active': 'cdn', 'site': site}) }}
      {{ include('Partial/flash-messages.html.twig', { 'flashBagMessages': app.session.flashbag.all }) }}
      {{ include('Partial/form-errors.html.twig', { 'formErrors': formErrors }) }}
      <div class="site-content">
        <h1>{% trans %}CDN{% endtrans %}</h1>

        {% if cdnNotConfigured %}
          <div class="alert alert-warning">
            {% trans %}BunnyCDN not configured. Admin → CDN → Settings.{% endtrans %}
          </div>
        {% elseif pullZone is null %}
          <p>{% trans %}This site does not yet have a BunnyCDN pull zone. Create one to start serving static assets via Bunny's edge network.{% endtrans %}</p>
          <form method="POST" action="{{ path('clp_site_cdn_enable', {'domainName': site.domainName}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('site-cdn-enable') }}">
            <button type="submit" class="btn btn-blue btn-lg">{% trans %}Create pull zone for this site{% endtrans %}</button>
          </form>
        {% else %}
          <div class="card card-table">
            <div class="card-header">{% trans %}Pull Zone{% endtrans %}</div>
            <div class="card-body">
              <dl class="row">
                <dt class="col-sm-3">{% trans %}Id{% endtrans %}</dt>
                <dd class="col-sm-9"><code>{{ pullZone.Id|default('?') }}</code></dd>

                <dt class="col-sm-3">{% trans %}Name{% endtrans %}</dt>
                <dd class="col-sm-9">{{ pullZone.Name|default('') }}</dd>

                <dt class="col-sm-3">{% trans %}Origin{% endtrans %}</dt>
                <dd class="col-sm-9"><code>{{ pullZone.OriginUrl|default('') }}</code></dd>

                <dt class="col-sm-3">{% trans %}Hostnames{% endtrans %}</dt>
                <dd class="col-sm-9">
                  {% if pullZone.Hostnames is defined and pullZone.Hostnames is iterable %}
                    <ul class="list-unstyled mb-0">
                      {% for h in pullZone.Hostnames %}
                        <li><code>{{ h.Value|default('') }}</code></li>
                      {% endfor %}
                    </ul>
                  {% else %}
                    <span class="text-muted">{% trans %}(none){% endtrans %}</span>
                  {% endif %}
                </dd>
              </dl>
              <p class="text-muted">
                {% trans %}Point a CNAME from{% endtrans %} <code>cdn.{{ site.domainName }}</code> {% trans %}to the hostname above to start serving traffic via BunnyCDN.{% endtrans %}
              </p>
            </div>
          </div>

          <form method="POST" action="{{ path('clp_site_cdn_disable', {'domainName': site.domainName}) }}" class="mt-3" onsubmit="return confirm('{% trans %}Delete this pull zone?{% endtrans %}');">
            <input type="hidden" name="_token" value="{{ csrf_token('site-cdn-disable') }}">
            <input type="hidden" name="pullZoneId" value="{{ pullZone.Id|default(0) }}">
            <button type="submit" class="btn btn-danger">{% trans %}Delete pull zone{% endtrans %}</button>
          </form>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
