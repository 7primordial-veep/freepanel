{% extends 'Frontend/layout.html.twig' %}

{% block pageTitle %}{% trans %}Settings{% endtrans %}{% endblock %}

{%- block stylesheets -%}
  {{ parent() }}
  <link href="{{ asset('/assets/css/frontend/account.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="account-container">
  <div class="page-header">
    <div class="page-title">
      <h1>{% trans %}Account{% endtrans %}</h1>
    </div>
  </div>
  <div class="page-content">
    <div class="account-content-container">
      {{ include('Frontend/User/Account/Partial/tab-container.html.twig', {'active': 'settings'}) }}
      {{ include('Partial/flash-messages.html.twig', { 'flashBagMessages': app.session.flashbag.all }) }}
      {{ include('Partial/form-errors.html.twig', { 'formErrors': formErrors }) }}
      {{ form_start(form) }}
        <div class="card">
          <div class="card-header">
            {% trans %}Settings{% endtrans %}
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-6 {{ (form_errors(form.userName) ? 'has-error' : '') }}">
                {{ form_label(form.userName, null, {'label_attr': {'class': 'col-form-label'}}) }}
                {{ form_widget(form.userName) }}
              </div>
              <div class="col-6 {{ (form_errors(form.email) ? 'has-error' : '') }}">
                {{ form_label(form.email, null, {'label_attr': {'class': 'col-form-label'}}) }}
                {{ form_widget(form.email) }}
              </div>
            </div>
            <div class="row">
              <div class="col-6 {{ (form_errors(form.firstName) ? 'has-error' : '') }}">
                {{ form_label(form.firstName, null, {'label_attr': {'class': 'col-form-label'}}) }}
                {{ form_widget(form.firstName) }}
              </div>
              <div class="col-6 {{ (form_errors(form.lastName) ? 'has-error' : '') }}">
                {{ form_label(form.lastName, null, {'label_attr': {'class': 'col-form-label'}}) }}
                {{ form_widget(form.lastName) }}
              </div>
            </div>
            <div class="row">
              <div class="col-6 {{ (form_errors(form.plainPassword) ? 'has-error' : '') }}">
                {{ form_label(form.plainPassword, null, {'label_attr': {'class': 'col-form-label'}}) }}
                {{ form_widget(form.plainPassword) }}
              </div>
              <div class="col-6 {{ (form_errors(form.timezone) ? 'has-error' : '') }}">
                {{ form_label(form.timezone, null, {'label_attr': {'class': 'col-form-label'}}) }}
                {{ form_widget(form.timezone) }}
              </div>
            </div>
        </div>
        <div class="card-footer text-end">
          {{ form_widget(form.submit) }}
        </div>
       </div>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}