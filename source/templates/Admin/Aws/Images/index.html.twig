{% extends 'Admin/layout.html.twig' %}

{% block pageTitle %}Amazon Web Services{% endblock %}

{% block sidebar -%}
  {{ include('Admin/Partial/sidebar.html.twig', {'active': 'aws'}) }}
{% endblock %}

{% block body %}
<div class="notifications-container">
  <div class="page-header">
    <div class="page-title">
      <h1>Amazon Web Services</h1>
    </div>
  </div>
  <div class="page-content">
    {{ include('Admin/Aws/Partial/tab-container.html.twig', {'active': 'images'}) }}
    {{ include('Partial/flash-messages.html.twig', { 'flashBagMessages': app.session.flashbag.all }) }}
    {{ include('Partial/form-errors.html.twig', { 'formErrors': formErrors }) }}
    <div class="aws-images-container">
      <div class="card card-table">
        <div class="card-header d-flex justify-content-between">
          {% trans %}Images{% endtrans %}
          <a href="{{ path('clp_admin_aws_image_create') }}" class="btn btn-md btn-blue">{% trans %}Create Image{% endtrans %}</a>
        </div>
        <div id="images-container">
          <div class="spinner-container m-3">
            <img src="{{ asset('assets/images/spinner.gif') }}" alt="{% trans %}Loading{% endtrans %}"> {% trans %}Loading{% endtrans %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
jQuery(document).ready(function() {
  jQuery.getJSON("{{path('clp_admin_aws_images_load')}}", function() {})
    .done(function(data) {
      if (data.errorMessage) {
        jQuery('#images-container').html(data.errorMessage);
      }
      if (data.imagesHtml) {
        jQuery('#images-container').html(data.imagesHtml);
      }
   }
  );
});
</script>
{% endblock %}