{% extends 'Admin/layout.html.twig' %}

{% block pageTitle %}{% trans %}Install Nextcloud{% endtrans %}{% endblock %}

{% block sidebar -%}
  {{ include('Admin/Partial/sidebar.html.twig', {'active': 'marketplace'}) }}
{% endblock %}

{% block body %}
{% set commands %}wget https://download.nextcloud.com/server/releases/latest.tar.bz2 -O /tmp/nc.tar.bz2
sudo -u {user} tar -xjf /tmp/nc.tar.bz2 -C /home/{user}/htdocs --strip-components=1
sudo -u {user} php -d memory_limit=512M /home/{user}/htdocs/occ maintenance:install --database=sqlite --admin-user=admin --admin-pass=changeme
rm -f /tmp/nc.tar.bz2{% endset %}

{% set warning %}<strong>{{ 'Security warning'|trans }}:</strong> {{ "The default admin password below is 'changeme'. Log in and change the admin password immediately after installation."|trans }}{% endset %}

{{ include('Admin/Marketplace/Partial/install-card.html.twig', {
  'title': 'Install Nextcloud'|trans,
  'warning': warning,
  'commands': commands,
  'sites': sites
}) }}
{% endblock %}
