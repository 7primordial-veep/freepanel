{% macro for_slug(slug) %}
  {%- if slug == 'wordpress' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" style="margin-right:12px;">
      <circle cx="12" cy="12" r="11" fill="#21759b"/>
      <text x="12" y="17" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="14" font-weight="bold" fill="#ffffff">W</text>
    </svg>
  {%- elseif slug == 'ghost' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" style="margin-right:12px;">
      <path d="M12 2 C7.6 2 4 5.6 4 10 L4 21 L6.5 19 L9 21 L12 19 L15 21 L17.5 19 L20 21 L20 10 C20 5.6 16.4 2 12 2 Z" fill="#15171a" stroke="#15171a" stroke-width="0.5" stroke-linejoin="round"/>
      <circle cx="15" cy="10" r="1.4" fill="#ffffff"/>
    </svg>
  {%- elseif slug == 'nextcloud' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" style="margin-right:12px;">
      <circle cx="12" cy="12" r="11" fill="#0082c9"/>
      <circle cx="8" cy="12" r="2.2" fill="#ffffff"/>
      <circle cx="12" cy="12" r="2.2" fill="#ffffff"/>
      <circle cx="16" cy="12" r="2.2" fill="#ffffff"/>
    </svg>
  {%- else -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" style="margin-right:12px;">
      <rect x="1" y="1" width="22" height="22" rx="2" fill="#9e9e9e"/>
      <text x="12" y="17" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="14" font-weight="bold" fill="#ffffff">{{ slug|first|upper }}</text>
    </svg>
  {%- endif -%}
{% endmacro %}
