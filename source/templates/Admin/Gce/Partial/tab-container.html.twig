{% if active is not defined %}
  {% set active = 'settings' %}
{% endif %}
<div class="tab-container">
  <ul>
    <li {% if active == 'settings' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_gce_settings') }}">{% trans %}Settings{% endtrans %}</a>
    </li>
    <li {% if active == 'snapshots' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_gce_snapshots') }}">{% trans %}Snapshots{% endtrans %}</a>
    </li>
  </ul>
</div>