{% if active is not defined %}
  {% set active = 'sidebar' %}
{% endif %}
<div id="sidebar" class="sidebar">
  <div class="back-to-sites">
    <a href="{{ path('clp_sites') }}">
      <svg width="14" height="14" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="chevron-left" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" class="svg-inline--fa fa-chevron-left fa-w-10"><path data-v-b18b6c7e="" fill="currentColor" d="M34.52 239.03L228.87 44.69c9.37-9.37 24.57-9.37 33.94 0l22.67 22.67c9.36 9.36 9.37 24.52.04 33.9L131.49 256l154.02 154.75c9.34 9.38 9.32 24.54-.04 33.9l-22.67 22.67c-9.37 9.37-24.57 9.37-33.94 0L34.52 272.97c-9.37-9.37-9.37-24.57 0-33.94z"></path></svg>
      {% trans %}Back to Sites{% endtrans %}
    </a>
  </div>
  <ul>
    <li {% if active == 'users' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_users') }}">{% trans %}Users{% endtrans %}</a>
    </li>
    <li {% if active == 'events' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_events') }}">{% trans %}Events{% endtrans %}</a>
    </li>
    <li {% if active == 'instance' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_services') }}">{% trans %}Instance{% endtrans %}</a>
    </li>
    {% if false == isMGT() %}
      <li {% if active == 'remote-backups' %}class="active"{% endif %}>
        <a href="{{ path('clp_admin_remote_backup') }}">{% trans %}Backups{% endtrans %}</a>
      </li>
      <li {% if active == 'security' %}class="active"{% endif %}>
        <a href="{{ path('clp_admin_firewall') }}">{% trans %}Security{% endtrans %}</a>
      </li>
    {% endif %}
    <li {% if active == 'certificates' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_certificates') }}">{% trans %}SSL Certificates{% endtrans %}</a>
    </li>
    <li {% if active == 'cloudflare' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_cloudflare_settings') }}">{% trans %}Cloudflare{% endtrans %}</a>
    </li>
    <li {% if active == 'marketplace' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_marketplace') }}">{% trans %}Marketplace{% endtrans %}</a>
    </li>
    <li {% if active == 'mailcow' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_mailcow') }}">{% trans %}Mailcow{% endtrans %}</a>
    </li>
    <li {% if active == 'malware-scan' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_malware_scan') }}">{% trans %}Malware Scan{% endtrans %}</a>
    </li>
    <li {% if active == 'sites-bulk' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_sites_bulk') }}">{% trans %}Bulk Site Ops{% endtrans %}</a>
    </li>
    <li {% if active == 'tools-headers' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_tools_headers') }}">{% trans %}Headers Tester{% endtrans %}</a>
    </li>
    <li {% if active == 'health' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_health') }}">{% trans %}Server Health{% endtrans %}</a>
    </li>
    <li {% if active == 'cdn' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_cdn') }}">{% trans %}CDN{% endtrans %}</a>
    </li>
    <li {% if active == 'settings' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_settings') }}">{% trans %}Settings{% endtrans %}</a>
    </li>
    {% if false == isMGT() %}
      {% if instance.environment.cloudProvider == constant('App\\CloudPanel\\Environment::CLOUD_PROVIDER_AWS') %}
        <li {% if active == 'aws' %}class="active"{% endif %}>
          <a href="{{ path('clp_admin_aws_settings') }}">Amazon Web Services</a>
        </li>
      {% endif %}
      {% if instance.environment.cloudProvider == constant('App\\CloudPanel\\Environment::CLOUD_PROVIDER_DO') %}
        <li {% if active == 'do' %}class="active"{% endif %}>
          <a href="{{ path('clp_admin_do_settings') }}">Digital Ocean</a>
        </li>
      {% endif %}
      {% if instance.environment.cloudProvider == constant('App\\CloudPanel\\Environment::CLOUD_PROVIDER_GCE') %}
        <li {% if active == 'gce' %}class="active"{% endif %}>
          <a href="{{ path('clp_admin_gce_settings') }}">Google Compute Engine</a>
        </li>
      {% endif %}
      {% if instance.environment.cloudProvider == constant('App\\CloudPanel\\Environment::CLOUD_PROVIDER_HETZNER') %}
        <li {% if active == 'hetzner' %}class="active"{% endif %}>
          <a href="{{ path('clp_admin_hetzner_settings') }}">Hetzner</a>
        </li>
      {% endif %}
      {% if instance.environment.cloudProvider == constant('App\\CloudPanel\\Environment::CLOUD_PROVIDER_VULTR') %}
        <li {% if active == 'vultr' %}class="active"{% endif %}>
          <a href="{{ path('clp_admin_vultr_settings') }}">Vultr</a>
        </li>
      {% endif %}
    {% endif %}
  </ul>
</div>
