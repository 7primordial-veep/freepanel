{% if active is not defined %}
  {% set active = 'services' %}
{% endif %}
<div class="tab-container">
  <ul>
    <li {% if active == 'services' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_services') }}">{% trans %}Services{% endtrans %}</a>
    </li>
    <li {% if active == 'settings' %}class="active"{% endif %}>
      <a href="{{ path('clp_admin_instance_settings') }}">{% trans %}Settings{% endtrans %}</a>
    </li>
  </ul>
</div>